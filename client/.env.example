VITE_API_BASE_URL=http://localhost:8000
VITE_MAX_UPLOAD_SIZE_MB=50

# For one-project Vercel deployment, omit this variable so production uses /api.
# For separate frontend/backend projects, set it to your backend Vercel URL.
# On Vercel direct API uploads must stay under the Vercel Function payload limit,
# so leave VITE_MAX_UPLOAD_SIZE_MB unset or set it to 4 unless you add direct Blob/S3 uploads.
