APP_NAME="Multi-Document Research Assistant"
APP_ENV=local
DEBUG=true
DATABASE_URL=sqlite:///./research_assistant.db
CLIENT_ORIGIN=http://localhost:5173

# Groq is used for text generation. Embeddings/retrieval remain local + ChromaDB.
GROQ_API_KEY=
GROQ_BASE_URL=https://api.groq.com
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_TEMPERATURE=0.2
GROQ_TIMEOUT_SECONDS=60

CHROMA_PERSIST_DIR=./chroma_db
CHROMA_COLLECTION_NAME=research_documents
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=50
EMBEDDING_PROVIDER=sentence_transformers
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
CHUNK_SIZE=1200
CHUNK_OVERLAP=200
RETRIEVAL_TOP_K=6
SUMMARY_TOP_K=8
REPORT_TOP_K=12

# Vercel notes:
# - In a one-project root deployment, omit VITE_API_BASE_URL in the frontend.
# - Set CLIENT_ORIGIN to your frontend origin for separate frontend/backend projects.
# - If DATABASE_URL, CHROMA_PERSIST_DIR, and UPLOAD_DIR are left as local defaults,
#   Vercel automatically falls back to /tmp runtime paths. /tmp is not durable.
# - Vercel automatically switches EMBEDDING_PROVIDER from sentence_transformers to
#   hashing to avoid bundling large local ML dependencies.
